#!/usr/bin/env bash
set -euo pipefail

{{- $isLinux := eq .chezmoi.os "linux" }}
{{- $kernelRelease := "" }}
{{- if $isLinux }}
{{- $kernelRelease = get .chezmoi.kernel "osrelease" }}
{{- end }}
{{- $isWSL := and $isLinux (contains "microsoft" (lower $kernelRelease)) }}

install_arch_packages() {
    local packages=(
        btop
        fd
        git
        go
{{- if not $isWSL }}
        hypridle
        hyprland
        hyprlock
        hyprpaper
        kitty
{{- end }}
        neovim
        nodejs
        npm
        python
        python-pip
        python-virtualenv
        ripgrep
        starship
        terraform
        tmux
{{- if not $isWSL }}
        ttf-font-awesome
        udiskie
        waybar
        wl-clipboard
{{- end }}
        yazi
        unzip
    )

    sudo pacman -S --needed --noconfirm "${packages[@]}"
}

install_ubuntu_packages() {
    local packages=(
        btop
        fd-find
        git
        golang-go
        kitty
        neovim
        nodejs
        npm
        python3
        python3-pip
        python3-venv
        ripgrep
        tmux
        unzip
    )

    sudo apt update
    sudo apt install -y "${packages[@]}"
}

install_macos_packages() {
    local packages=(
        btop
        fd
        git
        go
        neovim
        node
        python
        ripgrep
        starship
        hashicorp/tap/terraform
        tmux
        yazi
    )
    local casks=(
        font-jetbrains-mono-nerd-font
    )

    if ! command -v brew >/dev/null 2>&1; then
        echo "Homebrew is required to install packages on macOS: https://brew.sh" >&2
        exit 1
    fi

    brew tap hashicorp/tap
    brew install "${packages[@]}"
    brew install --cask "${casks[@]}"
}

{{- if eq .chezmoi.os "linux" }}
if command -v pacman >/dev/null 2>&1; then
    install_arch_packages
elif command -v apt >/dev/null 2>&1; then
    install_ubuntu_packages
else
    echo "No supported package manager found. Install packages manually." >&2
    exit 1
fi
{{- else if eq .chezmoi.os "darwin" }}
install_macos_packages
{{- else }}
echo "Package bootstrap is only configured for Linux and macOS. Skipping."
{{- end }}
