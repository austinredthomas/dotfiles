#!/usr/bin/env bash
set -euo pipefail

install_arch_packages() {
    local packages=(
        btop
        fd
        git
        go
        hypridle
        hyprland
        hyprlock
        hyprpaper
        kitty
        neovim
        nodejs
        npm
        python
        python-pip
        python-virtualenv
        ripgrep
        starship
        tmux
        ttf-font-awesome
        udiskie
        waybar
        wl-clipboard
        yazi
        unzip
    )

    sudo pacman -S --needed "${packages[@]}"
}

install_ubuntu_packages() {
    local packages=(
        btop
        fd-find
        git
        golang-go
        kitty
        neovim
        nodejs
        npm
        python3
        python3-pip
        python3-venv
        ripgrep
        tmux
        unzip
    )

    sudo apt update
    sudo apt install "${packages[@]}"
}

install_macos_packages() {
    local packages=(
        btop
        fd
        git
        go
        neovim
        node
        python
        ripgrep
        starship
        tmux
        yazi
    )

    if ! command -v brew >/dev/null 2>&1; then
        echo "Homebrew is required to install packages on macOS: https://brew.sh" >&2
        exit 1
    fi

    brew install "${packages[@]}"
}

{{- if eq .chezmoi.os "linux" }}
if command -v pacman >/dev/null 2>&1; then
    install_arch_packages
elif command -v apt >/dev/null 2>&1; then
    install_ubuntu_packages
else
    echo "No supported package manager found. Install packages manually." >&2
    exit 1
fi
{{- else if eq .chezmoi.os "darwin" }}
install_macos_packages
{{- else }}
echo "Package bootstrap is only configured for Linux and macOS. Skipping."
{{- end }}
